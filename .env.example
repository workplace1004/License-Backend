# Windows: if `npx prisma generate` fails with EBUSY (often under node_modules\prisma or @prisma\engines), run:
#   npm run generate:win
# Or exclude this folder from antivirus; use Node 20/22 LTS if issues persist.

# PostgreSQL (required). Create a database first, e.g. CREATE DATABASE pos_license;
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/pos_license?schema=public"

PORT=5050

# RSA signing (optional paths; default: ./keys/license-private.pem next to project root)
# LICENSE_RSA_PRIVATE_KEY_PATH=
# LICENSE_RSA_PRIVATE_KEY_PEM=
# LICENSE_RSA_PUBLIC_KEY_PATH=

# Strongly recommended in production. If unset, JWT signing uses a key derived from DATABASE_URL (works on Railway).
# After migrate, run: npm run db:seed  (default admin: admin@gmail.com / 123123 — change password in production).
# LICENSE_ADMIN_JWT_SECRET=

# Used for admin JWT signing if LICENSE_ADMIN_JWT_SECRET is unset. The issuer proxy (server.mjs) may send it as Bearer for legacy setups.
# POST /license/create does not require login; restrict who can reach the license API (firewall / private network) in production.
# LICENSE_ADMIN_SECRET=

# LICENSE_DEFAULT_VALIDITY_DAYS=365

# AES-256-GCM for encrypted license files (issuer download + POS import). 64 hex chars = 32 bytes.
# Must match VITE_LICENSE_FILE_ENCRYPTION_KEY in the POS frontend `.env`.
# Encrypted file includes RSA `license` + `signature` so the POS can verify offline (no DB hit on each app open).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# LICENSE_FILE_ENCRYPTION_KEY=
